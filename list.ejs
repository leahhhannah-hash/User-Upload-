<h1>Users List</h1>
<table border="1">
  <tr>
    <th>First Name</th>
    <th>Last Name</th>
    <th>Actions</th>
  </tr>
  <% users.forEach(user => { %>
  <tr>
    <td><%= user.first %></td>
    <td><%= user.last %></td>
    <td><a href="/users/<%= user.id %>">View Details</a></td>
  </tr>
  <% }) %>
</table>
<a href="/users/new">Add New User</a>